{
  "manifest_version": 2,
  "name": "LinkedIn Recruiter Blocker",
  "version": "1.0.0",
  "description": "Remove recruitment agencies and specific companies from LinkedIn job search results",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/jobs/*"],
      "js": ["src/filter.js", "src/storage.js", "src/content.js", "src/content-init.js"],
      "css": ["src/content.css"]
    }
  ],
  "browser_action": {
    "default_popup": "src/popup.html",
    "default_title": "Recruiter Blocker"
  }
}
